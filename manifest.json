{
  "manifest_version": 2,
  "name": "Tech Reader",
  "version": "0.1.0",
  "description": "帮助开发者摆脱翻译依赖，真正读懂英文技术文档",

  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["panel/panel.css"]
    }
  ],

  "web_accessible_resources": [
    "wordbook/wordbook.html",
    "wordbook/wordbook.css",
    "wordbook/wordbook.js"
  ],

  "browser_action": {
    "default_title": "Tech Reader 词库",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },

  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  },

  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "tech-reader@extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
